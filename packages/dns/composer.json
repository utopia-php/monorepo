{
    "name": "utopia-php/dns",
    "description": "Lite & fast micro PHP DNS server abstraction that is **easy to use**.",
    "type": "library",
    "keywords": [
        "php",
        "framework",
        "upf",
        "utopia",
        "dns"
    ],
    "license": "MIT",
    "minimum-stability": "stable",
    "scripts": {
        "test": "phpunit --configuration phpunit.xml --testsuite unit",
        "test:e2e": "phpunit --configuration phpunit.xml --testsuite e2e"
    },
    "authors": [
        {
            "name": "Eldad Fux",
            "email": "eldad@appwrite.io"
        }
    ],
    "autoload": {
        "psr-4": {
            "Utopia\\DNS\\": "src/DNS/"
        }
    },
    "require": {
        "php": ">=8.3",
        "utopia-php/span": "3.0.*",
        "utopia-php/telemetry": "^0.4",
        "utopia-php/validators": "0.*",
        "utopia-php/domains": "^2.0"
    },
    "require-dev": {
        "swoole/ide-helper": "5.1.8"
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true,
            "tbachert/spi": true
        }
    }
}
