      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          },
          "expr": "sum(rate(breaker_calls_total{circuit_breaker_name=\"$circuit\"}[2m])) by (circuit_breaker_outcome)",
          "legendFormat": "{{circuit_breaker_outcome}}",
          "refId": "A"
        }
      ],
      "title": "Call Outcomes",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "description": "Recent point events. Transition rows are emitted when the circuit changes state; probe rows are emitted for half-open calls.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            },
            "inspect": false
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Timestamp"
            },
            "properties": [
              {
                "id": "unit",
                "value": "dateTimeAsIso"
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 7
      },
      "id": 3,
      "options": {
        "cellHeight": "sm",
        "footer": {
          "countRows": false,
          "fields": "",
          "reducer": [
            "sum"
          ],
          "show": false
        },
        "showHeader": true,
        "sortBy": [
          {
            "desc": true,
            "displayName": "Timestamp"
          }
        ]
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          },
          "expr": "sort_desc(max by (circuit_breaker_name, circuit_breaker_event, circuit_breaker_event_name, circuit_breaker_from_state, circuit_breaker_to_state, circuit_breaker_outcome) ((breaker_event_timestamp_seconds{circuit_breaker_name=\"$circuit\"} and ((time() - breaker_event_timestamp_seconds{circuit_breaker_name=\"$circuit\"}) < $__range_s)) * 1000))",
          "format": "table",
          "instant": true,
          "legendFormat": "__auto",
          "range": false,
          "refId": "A"
        }
      ],
      "title": "Recent Transitions",
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "circuit_breaker_from_state": true,
              "circuit_breaker_to_state": true,
              "circuit_breaker_outcome": true
            },
            "indexByName": {
              "Value": 0,
              "circuit_breaker_name": 1,
              "circuit_breaker_event": 2,
              "circuit_breaker_event_name": 3
            },
            "renameByName": {
              "Value": "Timestamp",
              "circuit_breaker_event": "Type",
              "circuit_breaker_event_name": "Event",
              "circuit_breaker_name": "Circuit"
            }
          }
        }
      ],
      "type": "table"
    }
