includes:
    - ../../phpstan.neon

parameters:
    ignoreErrors:
        # Utopia\Telemetry\Adapter\Test creates anonymous subclasses of
        # Counter/Gauge/Histogram/UpDownCounter that expose a public $values
        # array. The declared base-class return types don't expose it, so
        # phpstan can't see the runtime-added property from tests.
        -
            message: '#Access to an undefined property Utopia\\Telemetry\\(Counter|Gauge|UpDownCounter|Histogram)::\$values\.#'
            path: tests/*
        # phpredis::getLastError() is guaranteed on the real Redis class; the
        # method_exists() guard stays for cases where a non-phpredis driver
        # is injected.
        -
            message: "#Call to function method_exists\\(\\) with Redis and 'getLastError' will always evaluate to true\\.#"
            path: tests/e2e/RedisAdapterTest.php
