{
    "name": "utopia-php/telemetry",
    "description": "A lite & fast telemetry library, with adapters for OpenTelemetry",
    "type": "library",
    "keywords": [
        "php",
        "framework",
        "upf"
    ],
    "license": "MIT",
    "minimum-stability": "stable",
    "autoload": {
        "psr-4": {
            "Utopia\\Telemetry\\": "src/Telemetry"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\Telemetry\\": "tests/Telemetry"
        }
    },
    "scripts": {
        "test": "phpunit --configuration phpunit.xml"
    },
    "require": {
        "ext-protobuf": "*",
        "ext-opentelemetry": "*",
        "php": ">=8.0",
        "open-telemetry/exporter-otlp": "1.*",
        "open-telemetry/sdk": "1.*",
        "psr/http-client": "^1.0",
        "psr/http-factory": "^1.0"
    },
    "require-dev": {
        "swoole/ide-helper": "6.*"
    },
    "suggest": {
        "utopia-php/client": "A PSR-18 client and PSR-17 factories to pass into the OpenTelemetry adapter",
        "ext-swoole": "Required for the Swoole transport implementation",
        "ext-sockets": "Required for the Swoole transport implementation"
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": false,
            "tbachert/spi": true
        }
    }
}
