#!/usr/bin/env php
<?php
/**
 * Utopia monorepo tool.
 *
 * Libraries live in packages/<name> and are distributed (read-only) to
 * github.com/utopia-php/<name> via `git subtree split`. Releases are made by
 * tagging the monorepo `<name>/<version>`, which pushes `<version>` to the
 * distribution repository for Packagist to pick up.
 */

chdir(dirname(__DIR__));

const ORG = 'utopia-php';
const SPLIT_APP_ID = 4016286; // GitHub App that pushes splits to the mirrors

function out(string $message): void
{
    fwrite(STDOUT, $message . PHP_EOL);
}

function fail(string $message): never
{
    fwrite(STDERR, 'error: ' . $message . PHP_EOL);
    exit(1);
}

/**
 * Run a command, return its stdout. Stderr streams through to the terminal.
 */
function sh(string $command): string
{
    exec($command, $output, $code);
    if ($code !== 0) {
        fail("command failed ({$code}): {$command}");
    }

    return trim(implode(PHP_EOL, $output));
}

/**
 * @return string[]
 */
function packages(): array
{
    return array_map('basename', glob('packages/*', GLOB_ONLYDIR));
}

/**
 * Distribution remote for a package. CI overrides the base with an
 * authenticated HTTPS URL via SPLIT_REMOTE_BASE.
 */
function remote(string $package): string
{
    $base = getenv('SPLIT_REMOTE_BASE') ?: 'git@github.com:' . ORG;

    return $base . '/' . $package . '.git';
}

function import_package(string $package, ?string $url, ?string $branch): void
{
    $url ??= 'https://github.com/' . ORG . "/{$package}.git";
    if (is_dir("packages/{$package}")) {
        fail("packages/{$package} already exists");
    }

    if ($branch === null) {
        preg_match('#refs/heads/(\S+)#', sh("git ls-remote --symref {$url} HEAD | head -n 1"), $match)
            || fail("cannot detect default branch of {$url}");
        $branch = $match[1];
    }

    out("importing {$package} from {$url} ({$branch})...");
    sh("git subtree add --prefix=packages/{$package} {$url} {$branch}");
    out("imported {$package}");
}

function mirror_workflow(string $package): string
{
    $yaml = <<<'YAML'
    name: Mirror

    on:
      pull_request_target:
        types: [opened]

    permissions:
      pull-requests: write

    jobs:
      redirect:
        runs-on: ubuntu-latest
        steps:
          - name: Redirect pull request to the monorepo
            env:
              GH_TOKEN: ${{ github.token }}
              PR: ${{ github.event.pull_request.html_url }}
            run: |
              gh pr comment "$PR" --body "Thanks for contributing! This repository is a read-only mirror — development for this library happens in [\`packages/{package}\`](https://github.com/utopia-php/monorepo/tree/main/packages/{package}) in the [utopia-php monorepo](https://github.com/utopia-php/monorepo). Please open this pull request there instead."
              gh pr close "$PR"
    YAML;

    return str_replace('{package}', $package, $yaml) . "\n";
}

function manifest(string $package): ?array
{
    $path = 'packages/' . $package . '/composer.json';
    if (!is_file($path)) {
        return null;
    }
    $manifest = json_decode(file_get_contents($path), true);

    return is_array($manifest) ? $manifest : null;
}

$arguments = array_slice($argv, 1);
$command = array_shift($arguments) ?? 'help';
$options = [];
$arguments = array_values(array_filter($arguments, function (string $argument) use (&$options): bool {
    if (!str_starts_with($argument, '--')) {
        return true;
    }
    [$key, $value] = array_pad(explode('=', substr($argument, 2), 2), 2, true);
    $options[$key] = $value;

    return false;
}));

switch ($command) {
    case 'list':
        foreach (packages() as $package) {
            $latest = sh("git tag --list '{$package}/*' --sort=-v:refname | head -n 1");
            out(str_pad($package, 24) . ($latest !== '' ? $latest : '(unreleased)'));
        }
        break;

    case 'import':
        $package = $arguments[0] ?? fail('usage: monorepo import <name> [url] [branch]');
        import_package($package, $arguments[1] ?? null, $arguments[2] ?? null);
        break;

    case 'absorb':
        $package = $arguments[0] ?? fail('usage: monorepo absorb <name> [url] [branch]');
        $directory = "packages/{$package}";

        if (!is_dir($directory)) {
            import_package($package, $arguments[1] ?? null, $arguments[2] ?? null);
        }

        // Strip QA tooling the monorepo hoists (see `check`).
        $path = "{$directory}/composer.json";
        $manifest = json_decode(file_get_contents($path), true);
        $original = $manifest;
        foreach (['laravel/pint', 'phpstan/phpstan', 'rector/rector', 'squizlabs/php_codesniffer'] as $dependency) {
            unset($manifest['require-dev'][$dependency]);
        }
        foreach (['format', 'format:check', 'lint', 'check', 'analyze', 'refactor', 'refactor:check'] as $script) {
            unset($manifest['scripts'][$script]);
        }
        if (($manifest['scripts'] ?? null) === []) {
            unset($manifest['scripts']);
        }
        if (is_file("{$directory}/pint.json")) {
            unlink("{$directory}/pint.json");
            out('removed pint.json (root config is canonical)');
        }
        if ($manifest !== $original) {
            file_put_contents($path, json_encode($manifest, JSON_PRETTY_PRINT | JSON_UNESCAPED_SLASHES | JSON_UNESCAPED_UNICODE) . "\n");
            out('stripped hoisted QA tooling from composer.json');
            if (is_file("{$directory}/composer.lock")) {
                passthru("cd {$directory} && composer update --no-interaction --no-progress --ignore-platform-reqs", $code);
                $code === 0 || fail("failed to refresh {$package} composer.lock");
            }
        }

        // Redirect pull requests opened against the mirror.
        @mkdir("{$directory}/.github/workflows", 0755, true);
        file_put_contents("{$directory}/.github/workflows/mirror.yml", mirror_workflow($package));
        out('wrote .github/workflows/mirror.yml (closes mirror PRs with a redirect)');

        // Point readers at the monorepo.
        $readme = "{$directory}/README.md";
        if (is_file($readme) && !str_contains($content = file_get_contents($readme), 'read-only mirror')) {
            $banner = "> [!IMPORTANT]\n"
                . "> This repository is a read-only mirror of the [utopia-php monorepo](https://github.com/utopia-php/monorepo). "
                . "Development happens in [`packages/{$package}`](https://github.com/utopia-php/monorepo/tree/main/packages/{$package}) — please open issues and pull requests there.\n";
            $updated = preg_replace('/^(# .+\R)/', "\$1\n{$banner}", $content, 1, $count);
            file_put_contents($readme, $count === 1 ? $updated : $banner . "\n" . $content);
            out('added mirror banner to README.md');
        }

        // Lock the mirror down: PR-only, no force-push, split app bypasses.
        exec('gh --version 2>/dev/null', $_, $missing);
        if ($missing !== 0) {
            out('gh not found — create the mirror ruleset manually (see README)');
        } else {
            $ruleset = json_encode([
                'name' => 'main',
                'target' => 'branch',
                'enforcement' => 'active',
                'conditions' => ['ref_name' => ['include' => ['~DEFAULT_BRANCH'], 'exclude' => []]],
                'rules' => [
                    ['type' => 'deletion'],
                    ['type' => 'non_fast_forward'],
                    ['type' => 'pull_request', 'parameters' => [
                        'required_approving_review_count' => 0,
                        'dismiss_stale_reviews_on_push' => false,
                        'require_code_owner_review' => false,
                        'require_last_push_approval' => false,
                        'required_review_thread_resolution' => false,
                        'allowed_merge_methods' => ['merge', 'squash', 'rebase'],
                    ]],
                ],
                'bypass_actors' => [['actor_id' => SPLIT_APP_ID, 'actor_type' => 'Integration', 'bypass_mode' => 'always']],
            ]);
            exec('echo ' . escapeshellarg($ruleset) . ' | gh api -X POST repos/' . ORG . "/{$package}/rulesets --input - 2>&1", $response, $code);
            if ($code === 0) {
                out('mirror ruleset created');
            } elseif (stripos($message = implode("\n", $response), 'already') !== false || stripos($message, 'must be unique') !== false) {
                out('mirror ruleset already exists');
            } else {
                out('could not create mirror ruleset (create manually, see README): ' . implode("\n", $response));
            }
        }

        out("absorbed {$package} — next: bin/monorepo check {$package} --fix, bin/monorepo test {$package}, "
            . "review {$directory}/.github/workflows for QA-only workflows to delete, then commit and push");
        break;

    case 'split':
        $targets = $arguments !== [] ? $arguments : packages();
        $failed = [];
        foreach ($targets as $package) {
            is_dir("packages/{$package}") || fail("unknown package: {$package}");

            out("splitting {$package}...");
            $sha = sh("git subtree split -q --prefix=packages/{$package}");

            if (isset($options['dry-run'])) {
                out("{$package} -> {$sha} (dry run)");
                continue;
            }

            $remote = is_string($options['remote'] ?? null) ? $options['remote'] : remote($package);
            $force = isset($options['force']) ? ' --force' : '';
            $ref = is_string($options['tag'] ?? null)
                ? 'refs/tags/' . $options['tag']
                : 'refs/heads/' . (is_string($options['branch'] ?? null) ? $options['branch'] : 'main');

            passthru("git push{$force} {$remote} {$sha}:{$ref}", $code);
            if ($code !== 0) {
                $failed[] = $package;
                continue;
            }
            out("{$package} -> {$ref} ({$sha})");
        }
        if ($failed !== []) {
            fail('failed to push: ' . implode(', ', $failed));
        }
        break;

    case 'validate':
        $failures = 0;
        foreach (packages() as $package) {
            $problems = [];
            $manifest = manifest($package);

            if ($manifest === null) {
                $problems[] = 'missing or invalid composer.json';
            } else {
                $expected = ORG . "/{$package}";
                if (($manifest['name'] ?? null) !== $expected) {
                    $problems[] = "name must be \"{$expected}\", got \"" . ($manifest['name'] ?? '') . '"';
                }
                if (empty($manifest['license'])) {
                    $problems[] = 'missing license';
                }
                if (isset($manifest['version'])) {
                    $problems[] = 'must not declare "version" (versions come from tags)';
                }
            }

            foreach ($problems as $problem) {
                out("packages/{$package}: {$problem}");
                $failures++;
            }
        }
        out($failures === 0 ? 'all packages valid' : "{$failures} problem(s) found");
        exit($failures === 0 ? 0 : 1);

    case 'check':
        $targets = $arguments !== [] ? $arguments : packages();

        if (!is_file('vendor/bin/pint')) {
            passthru('composer update --no-interaction --prefer-dist --no-progress', $code);
            $code === 0 || fail('failed to install the monorepo toolchain');
        }

        $failed = [];
        foreach ($targets as $package) {
            is_dir("packages/{$package}") || fail("unknown package: {$package}");

            out("==> {$package}");
            $directory = "packages/{$package}";

            // phpstan and rector reflect against the package's autoloader
            if (!is_dir("{$directory}/vendor")) {
                passthru("cd {$directory} && composer update --no-interaction --prefer-dist --no-progress --ignore-platform-reqs", $code);
                if ($code !== 0) {
                    $failed[] = "{$package} (composer)";
                    continue;
                }
            }

            $fix = isset($options['fix']);
            $checks = ['pint' => '../../vendor/bin/pint --config ../../pint.json' . ($fix ? '' : ' --test')];
            if (glob("{$directory}/phpstan.neon*") !== []) {
                $checks['phpstan'] = '../../vendor/bin/phpstan analyse --memory-limit=1G';
            }
            if (is_file("{$directory}/rector.php")) {
                $checks['rector'] = '../../vendor/bin/rector process' . ($fix ? '' : ' --dry-run');
            }

            foreach ($checks as $tool => $command) {
                passthru("cd {$directory} && {$command}", $code);
                if ($code !== 0) {
                    $failed[] = "{$package} ({$tool})";
                }
            }
        }
        if ($failed !== []) {
            fail('checks failed: ' . implode(', ', $failed));
        }
        out('all checks passed');
        break;

    case 'test':
        $targets = $arguments !== [] ? $arguments : packages();
        $failed = [];
        foreach ($targets as $package) {
            is_dir("packages/{$package}") || fail("unknown package: {$package}");

            out("==> {$package}");
            $directory = "packages/{$package}";

            // --ignore-platform-reqs: CI installs each package's declared
            // extensions, and exotic transitive ones (e.g. ext-opentelemetry)
            // must not block resolution.
            passthru("cd {$directory} && composer update --no-interaction --prefer-dist --no-progress --ignore-platform-reqs", $code);

            // Suites with a compose "tests" service run in containers (the
            // package's own CI convention); everything else runs locally.
            $compose = is_file("{$directory}/docker-compose.yml")
                && preg_match('/^ {2}tests:/m', file_get_contents("{$directory}/docker-compose.yml"));

            if ($code === 0 && $compose) {
                passthru("cd {$directory} && docker compose up -d --build && sleep 10 && docker compose exec -T tests vendor/bin/phpunit", $code);
                passthru("cd {$directory} && docker compose down -v --remove-orphans > /dev/null 2>&1");
            } elseif ($code === 0) {
                $runner = isset(manifest($package)['scripts']['test']) ? 'composer test' : './vendor/bin/phpunit';
                passthru("cd {$directory} && {$runner}", $code);
            }

            if ($code !== 0) {
                $failed[] = $package;
            }
        }
        if ($failed !== []) {
            fail('tests failed: ' . implode(', ', $failed));
        }
        out('all tests passed');
        break;

    default:
        out(<<<'HELP'
        usage: bin/monorepo <command>

          list                                show packages and their latest release tag
          import <name> [url] [branch]        import a library into packages/<name>, preserving history
          absorb <name> [url] [branch]        import (if needed) + strip hoisted QA + mirror PR redirect + lockdown
          split [name...] [--tag=v] [--branch=main] [--remote=url] [--force] [--dry-run]
                                              push package subtrees to their distribution repositories
          validate                            check package composer.json conventions
          check [name...] [--fix]             run pint, phpstan and rector against packages
          test [name...]                      install dependencies and run package test suites
        HELP);
        break;
}
