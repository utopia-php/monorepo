#!/usr/bin/env php
<?php
/**
 * Utopia monorepo tool.
 *
 * Libraries live in packages/<name> and are distributed (read-only) to
 * github.com/utopia-php/<name> as synthesized split histories. Releases are
 * made by tagging the monorepo `<name>/<version>`, which pushes `<version>`
 * to the distribution repository for Packagist to pick up.
 */

chdir(dirname(__DIR__));

const ORG = 'utopia-php';
const SPLIT_APP_ID = 4016286; // GitHub App that pushes splits to the mirrors

function out(string $message): void
{
    fwrite(STDOUT, $message . PHP_EOL);
}

function fail(string $message): never
{
    fwrite(STDERR, 'error: ' . $message . PHP_EOL);
    exit(1);
}

/**
 * Run a command, return its stdout. Stderr streams through to the terminal.
 */
function sh(string $command): string
{
    exec($command, $output, $code);
    if ($code !== 0) {
        fail("command failed ({$code}): {$command}");
    }

    return trim(implode(PHP_EOL, $output));
}

/**
 * @return string[]
 */
function packages(): array
{
    return array_map('basename', glob('packages/*', GLOB_ONLYDIR));
}

/**
 * Distribution remote for a package. CI overrides the base with an
 * authenticated HTTPS URL via SPLIT_REMOTE_BASE.
 */
function remote(string $package): string
{
    $base = getenv('SPLIT_REMOTE_BASE') ?: 'git@github.com:' . ORG;

    return $base . '/' . $package . '.git';
}

function import_package(string $package, ?string $url, ?string $branch): void
{
    $url ??= 'https://github.com/' . ORG . "/{$package}.git";
    if (is_dir("packages/{$package}")) {
        fail("packages/{$package} already exists");
    }

    if ($branch === null) {
        preg_match('#refs/heads/(\S+)#', sh("git ls-remote --symref {$url} HEAD | head -n 1"), $match)
            || fail("cannot detect default branch of {$url}");
        $branch = $match[1];
    }

    out("importing {$package} from {$url} ({$branch})...");
    sh("git subtree add --prefix=packages/{$package} {$url} {$branch}");
    out("imported {$package}");
}

function mirror_workflow(string $package): string
{
    $yaml = <<<'YAML'
    name: Mirror

    on:
      pull_request_target:
        types: [opened]

    permissions:
      pull-requests: write

    jobs:
      redirect:
        runs-on: ubuntu-latest
        steps:
          - name: Redirect pull request to the monorepo
            env:
              GH_TOKEN: ${{ github.token }}
              PR: ${{ github.event.pull_request.html_url }}
            run: |
              gh pr comment "$PR" --body "Thanks for contributing! This repository is a read-only mirror — development for this library happens in [\`packages/{package}\`](https://github.com/utopia-php/monorepo/tree/main/packages/{package}) in the [utopia-php monorepo](https://github.com/utopia-php/monorepo). Please open this pull request there instead."
              gh pr close "$PR"
    YAML;

    return str_replace('{package}', $package, $yaml) . "\n";
}

/**
 * Ensure the root toolchain (pint, phpstan, rector, phpunit) is installed and
 * on PATH, so package scripts resolve `phpunit` to the monorepo's version.
 */
function toolchain(): void
{
    if (!is_file('vendor/bin/phpunit')) {
        passthru('composer update --no-interaction --prefer-dist --no-progress', $code);
        $code === 0 || fail('failed to install the monorepo toolchain');
    }
    putenv('PATH=' . getcwd() . '/vendor/bin:' . getenv('PATH'));
}

/**
 * Release notes for a package version: every monorepo commit that touched the
 * package since its previous release tag, plus a compare link.
 */
function release_notes(string $package, string $version, string $to): string
{
    $previous = null;
    $tags = sh("git -c versionsort.suffix=- tag --list '{$package}/*' --sort=-v:refname");
    foreach (explode("\n", $tags) as $tag) {
        $candidate = substr($tag, strlen($package) + 1);
        if ($candidate !== '' && version_compare($candidate, $version, '<')) {
            $previous = $tag;
            break;
        }
    }

    if ($previous === null) {
        return "First release cut from the [utopia-php monorepo](https://github.com/utopia-php/monorepo/tree/main/packages/{$package}).";
    }

    $log = sh("git log {$previous}..{$to} --pretty='- %s' -- packages/{$package}");

    return ($log !== '' ? $log : '- No changes to this package since ' . $previous . '.')
        . "\n\n**Changes**: https://github.com/utopia-php/monorepo/compare/{$previous}...{$package}/{$version}";
}

/**
 * Compute a package's split head: starting from the latest subtree
 * annotation (an import or rejoin merge), re-synthesize one commit per
 * mainline commit that changed the package, copying tree, author, committer
 * and raw message. Deterministic, and byte-identical to `git subtree split`
 * output — without its fatal cache collision when a package is re-imported.
 */
function split_package(string $package): string
{
    $join = sh('git log --format=%H --grep=' . escapeshellarg("^git-subtree-dir: packages/{$package}\$") . ' -1 HEAD');
    $join !== '' || fail("packages/{$package} has no subtree annotation — was it imported?");
    $body = sh("git log --format=%B -1 {$join}");
    preg_match('/^git-subtree-mainline: (\w+)$/m', $body, $mainline) || fail("no git-subtree-mainline in {$join}");
    preg_match('/^git-subtree-split: (\w+)$/m', $body, $split) || fail("no git-subtree-split in {$join}");

    $tip = $split[1];
    $commits = sh("git log --reverse --first-parent --format=%H {$mainline[1]}..HEAD -- packages/{$package}");
    foreach (array_filter(explode("\n", $commits)) as $commit) {
        unset($tree);
        exec("git rev-parse -q --verify {$commit}:packages/{$package} 2>/dev/null", $tree, $missing);
        if ($missing !== 0 || $tree[0] === sh("git rev-parse {$tip}^{tree}")) {
            continue;
        }
        $identity = explode("\x1f", sh("git log -1 --format=%an%x1f%ae%x1f%aD%x1f%cn%x1f%ce%x1f%cD {$commit}"));
        $environment = '';
        foreach (['GIT_AUTHOR_NAME', 'GIT_AUTHOR_EMAIL', 'GIT_AUTHOR_DATE', 'GIT_COMMITTER_NAME', 'GIT_COMMITTER_EMAIL', 'GIT_COMMITTER_DATE'] as $index => $variable) {
            $environment .= $variable . '=' . escapeshellarg($identity[$index]) . ' ';
        }
        $tip = sh("git log -1 --pretty=format:%B {$commit} | {$environment}git commit-tree {$tree[0]} -p {$tip}");
    }

    return $tip;
}

function manifest(string $package): ?array
{
    $path = 'packages/' . $package . '/composer.json';
    if (!is_file($path)) {
        return null;
    }
    $manifest = json_decode(file_get_contents($path), true);

    return is_array($manifest) ? $manifest : null;
}

/**
 * Local siblings in a package's dependency graph, mapped to a version that
 * satisfies the requiring constraint (e.g. "^0.20" → "0.20.999"), so a path
 * repository can stand in for Packagist during linked test runs.
 *
 * @return array<string, string>
 */
function linked_versions(string $package): array
{
    $versions = [];
    $pending = [$package];
    $seen = [$package => true];
    while ($pending !== []) {
        $current = array_shift($pending);
        foreach (manifest($current)['require'] ?? [] as $dependency => $constraint) {
            if (!str_starts_with($dependency, ORG . '/')) {
                continue;
            }
            $sibling = substr($dependency, strlen(ORG) + 1);
            if (!is_dir("packages/{$sibling}") || isset($seen[$sibling])) {
                continue;
            }
            $seen[$sibling] = true;
            if (preg_match('/\d+(?:\.\d+)*/', $constraint, $match)) {
                $parts = explode('.', $match[0]);
                $versions[$dependency] = $parts[0] . '.' . ($parts[1] ?? '0') . '.999';
                $pending[] = $sibling;
            }
        }
    }

    return $versions;
}

$arguments = array_slice($argv, 1);
$command = array_shift($arguments) ?? 'help';
$options = [];
$arguments = array_values(array_filter($arguments, function (string $argument) use (&$options): bool {
    if (!str_starts_with($argument, '--')) {
        return true;
    }
    [$key, $value] = array_pad(explode('=', substr($argument, 2), 2), 2, true);
    $options[$key] = $value;

    return false;
}));

switch ($command) {
    case 'list':
        foreach (packages() as $package) {
            $latest = sh("git tag --list '{$package}/*' --sort=-v:refname | head -n 1");
            out(str_pad($package, 24) . ($latest !== '' ? $latest : '(unreleased)'));
        }
        break;

    case 'import':
        $package = $arguments[0] ?? fail('usage: monorepo import <name> [url] [branch]');
        import_package($package, $arguments[1] ?? null, $arguments[2] ?? null);
        break;

    case 'absorb':
        $package = $arguments[0] ?? fail('usage: monorepo absorb <name> [url] [branch]');
        $directory = "packages/{$package}";

        if (!is_dir($directory)) {
            import_package($package, $arguments[1] ?? null, $arguments[2] ?? null);
        }

        // Strip QA tooling the monorepo hoists (see `check`).
        $path = "{$directory}/composer.json";
        $manifest = json_decode(file_get_contents($path), true);
        $original = $manifest;
        foreach (['laravel/pint', 'phpstan/phpstan', 'rector/rector', 'squizlabs/php_codesniffer', 'phpunit/phpunit'] as $dependency) {
            unset($manifest['require-dev'][$dependency]);
        }
        foreach (['format', 'format:check', 'lint', 'check', 'analyze', 'refactor', 'refactor:check'] as $script) {
            unset($manifest['scripts'][$script]);
        }
        foreach ($manifest['scripts'] ?? [] as $name => $script) {
            if (is_string($script)) {
                // phpunit comes from the root toolchain, resolved via PATH
                $manifest['scripts'][$name] = preg_replace('#(\./)?vendor/bin/phpunit#', 'phpunit', $script);
            }
        }
        if (($manifest['scripts'] ?? null) === []) {
            unset($manifest['scripts']);
        }
        if (($manifest['require-dev'] ?? null) === []) {
            unset($manifest['require-dev']);
        }
        if (is_file("{$directory}/pint.json")) {
            unlink("{$directory}/pint.json");
            out('removed pint.json (root config is canonical)');
        }
        if ($manifest !== $original) {
            file_put_contents($path, json_encode($manifest, JSON_PRETTY_PRINT | JSON_UNESCAPED_SLASHES | JSON_UNESCAPED_UNICODE) . "\n");
            out('stripped hoisted QA tooling from composer.json');
            if (is_file("{$directory}/composer.lock")) {
                passthru("cd {$directory} && composer update --no-interaction --no-progress --ignore-platform-reqs", $code);
                $code === 0 || fail("failed to refresh {$package} composer.lock");
            }
        }

        // Redirect pull requests opened against the mirror.
        @mkdir("{$directory}/.github/workflows", 0755, true);
        file_put_contents("{$directory}/.github/workflows/mirror.yml", mirror_workflow($package));
        out('wrote .github/workflows/mirror.yml (closes mirror PRs with a redirect)');

        // Point readers at the monorepo.
        $readme = "{$directory}/README.md";
        if (is_file($readme) && !str_contains($content = file_get_contents($readme), 'read-only mirror')) {
            $banner = "> [!IMPORTANT]\n"
                . "> This repository is a read-only mirror of the [utopia-php monorepo](https://github.com/utopia-php/monorepo). "
                . "Development happens in [`packages/{$package}`](https://github.com/utopia-php/monorepo/tree/main/packages/{$package}) — please open issues and pull requests there.\n";
            $updated = preg_replace('/^(# .+\R)/', "\$1\n{$banner}", $content, 1, $count);
            file_put_contents($readme, $count === 1 ? $updated : $banner . "\n" . $content);
            out('added mirror banner to README.md');
        }

        // Lock the mirror down: PR-only, no force-push, split app bypasses.
        exec('gh --version 2>/dev/null', $_, $missing);
        if ($missing !== 0) {
            out('gh not found — create the mirror ruleset manually (see README)');
        } else {
            $ruleset = json_encode([
                'name' => 'main',
                'target' => 'branch',
                'enforcement' => 'active',
                'conditions' => ['ref_name' => ['include' => ['~DEFAULT_BRANCH'], 'exclude' => []]],
                'rules' => [
                    ['type' => 'deletion'],
                    ['type' => 'non_fast_forward'],
                    ['type' => 'pull_request', 'parameters' => [
                        'required_approving_review_count' => 0,
                        'dismiss_stale_reviews_on_push' => false,
                        'require_code_owner_review' => false,
                        'require_last_push_approval' => false,
                        'required_review_thread_resolution' => false,
                        'allowed_merge_methods' => ['merge', 'squash', 'rebase'],
                    ]],
                ],
                'bypass_actors' => [['actor_id' => SPLIT_APP_ID, 'actor_type' => 'Integration', 'bypass_mode' => 'always']],
            ]);
            exec('printf %s ' . escapeshellarg($ruleset) . ' | gh api -X POST repos/' . ORG . "/{$package}/rulesets --input - 2>&1", $response, $code);
            if ($code === 0) {
                out('mirror ruleset created');
            } elseif (stripos($message = implode("\n", $response), 'already') !== false || stripos($message, 'must be unique') !== false) {
                out('mirror ruleset already exists');
            } else {
                out('could not create mirror ruleset (create manually, see README): ' . implode("\n", $response));
            }
        }

        out("absorbed {$package} — next: bin/monorepo check {$package} --fix, bin/monorepo test {$package}, "
            . "review {$directory}/.github/workflows for QA-only workflows to delete, then commit and push");
        break;

    case 'split':
        $targets = $arguments !== [] ? $arguments : packages();
        $failed = [];
        foreach ($targets as $package) {
            is_dir("packages/{$package}") || fail("unknown package: {$package}");

            out("splitting {$package}...");
            $sha = split_package($package);

            if (isset($options['dry-run'])) {
                out("{$package} -> {$sha} (dry run)");
                continue;
            }

            $remote = is_string($options['remote'] ?? null) ? $options['remote'] : remote($package);
            $force = isset($options['force']) ? ' --force' : '';
            $ref = is_string($options['tag'] ?? null)
                ? 'refs/tags/' . $options['tag']
                : 'refs/heads/' . (is_string($options['branch'] ?? null) ? $options['branch'] : 'main');

            passthru("git push{$force} {$remote} {$sha}:{$ref}", $code);
            if ($code !== 0) {
                $failed[] = $package;
                continue;
            }
            out("{$package} -> {$ref} ({$sha})");

            // A pushed tag gets a GitHub release on the mirror, with notes
            // derived from the monorepo log.
            if (is_string($options['tag'] ?? null)) {
                $version = $options['tag'];
                $tag = "{$package}/{$version}";
                exec("git rev-parse -q --verify refs/tags/{$tag} > /dev/null 2>&1", $_, $missing);
                $payload = json_encode([
                    'tag_name' => $version,
                    'name' => $version,
                    'body' => release_notes($package, $version, $missing === 0 ? $tag : 'HEAD'),
                    'prerelease' => str_contains($version, '-'),
                ]);
                exec('printf %s ' . escapeshellarg($payload) . ' | gh api -X POST repos/' . ORG . "/{$package}/releases --input - 2>&1", $response, $code);
                if ($code === 0) {
                    out("{$package} -> release {$version} published");
                } elseif (stripos($message = implode("\n", $response), 'already_exists') !== false) {
                    out("release {$version} already exists");
                } else {
                    out("could not publish release: {$message}");
                    $failed[] = "{$package} (release)";
                }
            }
        }
        if ($failed !== []) {
            fail('failed to push: ' . implode(', ', $failed));
        }
        break;

    case 'release':
        $package = $arguments[0] ?? fail('usage: monorepo release <package> <version> [--dry-run]');
        $version = $arguments[1] ?? fail('usage: monorepo release <package> <version> [--dry-run]');
        is_dir("packages/{$package}") || fail("unknown package: {$package}");
        preg_match('/^\d+\.\d+\.\d+(-[0-9A-Za-z.]+)?$/', $version)
            || fail("version must be semver (e.g. 2.1.0 or 2.1.0-rc1), got \"{$version}\"");

        $tag = "{$package}/{$version}";
        if (sh('git tag --list ' . escapeshellarg($tag)) !== '') {
            fail("tag {$tag} already exists");
        }

        out("release notes for {$tag}:\n");
        out(release_notes($package, $version, 'HEAD') . "\n");

        if (isset($options['dry-run'])) {
            out('(dry run — nothing tagged)');
            break;
        }

        if (sh('git status --porcelain') !== '') {
            fail('working tree is dirty — commit or stash before releasing');
        }
        exec('git merge-base --is-ancestor HEAD origin/main', $_, $unmerged);
        if ($unmerged !== 0) {
            out('warning: HEAD is not on origin/main — you are releasing unmerged commits');
        }

        sh("git tag {$tag}");
        sh("git push origin {$tag}");
        out("pushed {$tag} — CI will mirror the tag, publish to Packagist, and create the GitHub release");
        break;

    case 'validate':
        $failures = 0;
        foreach (packages() as $package) {
            $problems = [];
            $manifest = manifest($package);

            if ($manifest === null) {
                $problems[] = 'missing or invalid composer.json';
            } else {
                $expected = ORG . "/{$package}";
                if (($manifest['name'] ?? null) !== $expected) {
                    $problems[] = "name must be \"{$expected}\", got \"" . ($manifest['name'] ?? '') . '"';
                }
                if (empty($manifest['license'])) {
                    $problems[] = 'missing license';
                }
                if (isset($manifest['version'])) {
                    $problems[] = 'must not declare "version" (versions come from tags)';
                }
            }

            foreach ($problems as $problem) {
                out("packages/{$package}: {$problem}");
                $failures++;
            }
        }
        out($failures === 0 ? 'all packages valid' : "{$failures} problem(s) found");
        exit($failures === 0 ? 0 : 1);

    case 'check':
        $targets = $arguments !== [] ? $arguments : packages();
        toolchain();
        $failed = [];
        foreach ($targets as $package) {
            is_dir("packages/{$package}") || fail("unknown package: {$package}");

            out("==> {$package}");
            $directory = "packages/{$package}";

            // phpstan and rector reflect against the package's autoloader
            if (!is_dir("{$directory}/vendor")) {
                passthru("cd {$directory} && composer update --no-interaction --prefer-dist --no-progress --ignore-platform-reqs", $code);
                if ($code !== 0) {
                    $failed[] = "{$package} (composer)";
                    continue;
                }
            }

            $fix = isset($options['fix']);
            $checks = ['pint' => '../../vendor/bin/pint --config ../../pint.json' . ($fix ? '' : ' --test')];
            if (glob("{$directory}/phpstan.neon*") !== []) {
                $checks['phpstan'] = '../../vendor/bin/phpstan analyse --memory-limit=1G';
            }
            if (is_file("{$directory}/rector.php")) {
                $checks['rector'] = '../../vendor/bin/rector process' . ($fix ? '' : ' --dry-run');
            }

            foreach ($checks as $tool => $command) {
                passthru("cd {$directory} && {$command}", $code);
                if ($code !== 0) {
                    $failed[] = "{$package} ({$tool})";
                }
            }
        }
        if ($failed !== []) {
            fail('checks failed: ' . implode(', ', $failed));
        }
        out('all checks passed');
        break;

    case 'dependents':
        $targets = $arguments !== [] ? $arguments : fail('usage: monorepo dependents <name...>');

        $dependents = [];
        foreach (packages() as $candidate) {
            foreach (manifest($candidate)['require'] ?? [] as $dependency => $constraint) {
                if (str_starts_with($dependency, ORG . '/')) {
                    $dependents[substr($dependency, strlen(ORG) + 1)][] = $candidate;
                }
            }
        }

        $found = [];
        $pending = $targets;
        while ($pending !== []) {
            foreach ($dependents[array_shift($pending)] ?? [] as $dependent) {
                if (!isset($found[$dependent])) {
                    $found[$dependent] = true;
                    $pending[] = $dependent;
                }
            }
        }
        foreach (array_keys($found) as $dependent) {
            out($dependent);
        }
        break;

    case 'test':
        $targets = $arguments !== [] ? $arguments : packages();
        toolchain();
        $failed = [];
        foreach ($targets as $package) {
            is_dir("packages/{$package}") || fail("unknown package: {$package}");

            out("==> {$package}");
            $directory = "packages/{$package}";

            // --linked: resolve monorepo siblings from the local checkout
            // instead of Packagist, via a generated manifest (COMPOSER env)
            // with a path repository claiming constraint-satisfying versions.
            $environment = '';
            if (isset($options['linked'])) {
                $versions = linked_versions($package);
                if ($versions === []) {
                    out('no local siblings to link; running registry-resolved');
                } else {
                    $manifest = manifest($package);
                    $manifest['repositories'] = array_merge([[
                        'type' => 'path',
                        'url' => '../*',
                        'options' => ['symlink' => true, 'versions' => $versions],
                    ]], $manifest['repositories'] ?? []);
                    file_put_contents("{$directory}/composer.linked.json", json_encode($manifest, JSON_PRETTY_PRINT | JSON_UNESCAPED_SLASHES | JSON_UNESCAPED_UNICODE) . "\n");
                    $environment = 'COMPOSER=composer.linked.json ';
                    out('linked: ' . implode(', ', array_keys($versions)));
                }
            }

            // --ignore-platform-reqs: CI installs each package's declared
            // extensions, and exotic transitive ones (e.g. ext-opentelemetry)
            // must not block resolution.
            passthru("cd {$directory} && {$environment}composer update --no-interaction --prefer-dist --no-progress --ignore-platform-reqs", $code);

            // The test contract: `composer test` is the unit tier and runs on
            // a bare host; `composer test:e2e` runs on the host against the
            // package's compose services.
            if ($code === 0) {
                $runner = isset(manifest($package)['scripts']['test']) ? 'composer test' : 'phpunit';
                passthru("cd {$directory} && {$environment}{$runner}", $code);
            }

            if ($code === 0 && isset(manifest($package)['scripts']['test:e2e'])) {
                $compose = is_file("{$directory}/docker-compose.yml");
                if ($compose) {
                    passthru("cd {$directory} && docker compose up -d --build --wait", $code);
                }
                if ($code === 0) {
                    passthru("cd {$directory} && {$environment}composer test:e2e", $code);
                }
                if ($compose) {
                    passthru("cd {$directory} && docker compose down -v --remove-orphans > /dev/null 2>&1");
                }
            }

            if ($code !== 0) {
                $failed[] = $package;
            }
        }
        if ($failed !== []) {
            fail('tests failed: ' . implode(', ', $failed));
        }
        out('all tests passed');
        break;

    default:
        out(<<<'HELP'
        usage: bin/monorepo <command>

          list                                show packages and their latest release tag
          import <name> [url] [branch]        import a library into packages/<name>, preserving history
          absorb <name> [url] [branch]        import (if needed) + strip hoisted QA + mirror PR redirect + lockdown
          split [name...] [--tag=v] [--branch=main] [--remote=url] [--force] [--dry-run]
                                              push package subtrees to their distribution repositories
          release <name> <version> [--dry-run]
                                              preview notes, tag <name>/<version> and push it (CI does the rest)
          validate                            check package composer.json conventions
          check [name...] [--fix]             run pint, phpstan and rector against packages
          test [name...] [--linked]           install dependencies and run package test suites
                                              (--linked resolves monorepo siblings from the local checkout)
          dependents <name...>                list packages that depend on the given ones (transitively)
        HELP);
        break;
}
