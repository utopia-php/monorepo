{
    "name": "utopia-php/di",
    "description": "A simple and lite library for managing dependency injections",
    "type": "library",
    "keywords": [
        "php",
        "di",
        "dependency-injection",
        "container",
        "psr-11",
        "utopia"
    ],
    "license": "MIT",
    "require": {
        "php": ">=8.2",
        "psr/container": "^2.0"
    },
    "require-dev": {
        "phpbench/phpbench": "^1.2",
        "swoole/ide-helper": "4.8.3"
    },
    "autoload": {
        "psr-4": {
            "Utopia\\": "src/",
            "Tests\\E2E\\": "tests/e2e"
        }
    },
    "config": {
        "platform": {
            "php": "8.2"
        }
    },
    "scripts": {
        "test": "phpunit --configuration phpunit.xml"
    }
}
