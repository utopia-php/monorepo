{
    "name": "nats/nats",
    "description": "Modern PHP client for NATS messaging system",
    "type": "library",
    "license": "Apache-2.0",
    "keywords": ["nats", "messaging", "pubsub", "jetstream", "queue"],
    "require": {
        "php": ">=8.1",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "suggest": {
        "ext-sodium": "Required for NKey and JWT credential authentication"
    },
    "autoload": {
        "psr-4": {
            "Nats\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Nats\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    }
}
